{
  "name": "@ublacklist/builtin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "pnpm run /^check:/",
    "check:biome": "biome check",
    "check:prettier": "prettier --check **/*.{md,yaml,yml}",
    "check:typescript": "tsgo",
    "fix": "pnpm run /^fix:/",
    "fix:biome": "biome check --write",
    "fix:prettier": "prettier --write **/*.{md,yaml,yml}",
    "update-searxng-instances": "node ./scripts/update-searxng-instances.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1"
  },
  "packageManager": "pnpm@10.32.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.14.0",
      "onFail": "download"
    }
  }
}
